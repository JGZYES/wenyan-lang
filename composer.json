{
    "name": "jgzyes/wenyan-lang",
    "type": "flarum-extension",
    "description": "Flarum in classical Chinese grammar, Simplified script — elegant and concise.",
    "keywords": [
        "locale",
        "文言",
        "language"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "JGZ_YES",
            "email": "luoriguodu@qq.com",
            "role": "Developer"
        },
        {
            "name": "Xiaoxiaobai5724",
            "email": "odoorbell@163.com",
            "role": "Developer"
        }
    ],
    "support": {
    	"source": "https://github.com/JGZYES/wenyan-lang",
    	"issues": "https://github.com/JGZYES/wenyan-lang/issues"
  },
    "require": {
        "flarum/core": "^1.8"
    },
    "extra": {
        "branch-alias": {
            "dev-main": "2.x-dev"
        },
        "flarum-extension": {
            "title": "文言",
            "category": "language",
            "icon": {
                "image": "icon.png",
                "backgroundColor": "#F4F2EE",
                "backgroundSize": "cover",
                "backgroundPosition": "center"
            }
        },
        "flarum-locale": {
            "code": "zh-wenyan",
            "title": "文言"
        }
    }
}
